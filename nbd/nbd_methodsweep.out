    ("detune_p0p30", 3.556),
    ("detune_p0p40", 3.656),
    ("detune_p0p50", 3.756),
]

# Four cavity Hamiltonian variants x two response levels = eight models.
MODEL_SPECS = [
    ("TDA_PF", "TDA", "PF"),
    ("TDA_Rabi", "TDA", "Rabi"),
    ("TDA_RWA", "TDA", "RWA"),
