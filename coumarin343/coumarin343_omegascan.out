import sys
# Bulletproof path injection for the qed module
sys.path.insert(0, "/global/scratch/users/vaibhavvaiyakarnam/bdp_tddft/qed_tddft")

import numpy
from pyscf import gto, scf, tdscf
import qed

# ==========================================
# 1. MOLECULE SETUP: Coumarin 343
# ==========================================
mol = gto.Mole()
mol.verbose = 4
mol.atom = '''
C  -5.585634936212   2.449611799944  -0.108879421850
C  -6.783460232473   1.586846081547  -0.515400637148
