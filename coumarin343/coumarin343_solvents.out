'''
mol.basis = '6-31+G**'
mol.build()

# ==========================================
# 2. DEFINE ENVIRONMENTS TO TEST
# ==========================================
# List format: [("Name", Dielectric Constant)]
environments = [
    ("PMMA Matrix", 3.0),
    ("Water", 78.35)
]

# ==========================================
# 3. LOOP THROUGH ENVIRONMENTS
# ==========================================
for env_name, eps_value in environments:
    
    print("\n" + "="*80)
    print(f"   STARTING CALCULATION: {env_name.upper()} (Dielectric Constant: {eps_value})")
    print("="*80)
    
    # --- A. Ground State SCF with ddCOSMO ---
    mf = scf.RKS(mol)
    mf.xc = 'b3lyp'
    mf = mf.ddCOSMO()               # Activate solvent model
    mf.with_solvent.eps = eps_value # Set specific dielectric constant
    mf.kernel()
    
    # --- B. TD-DFT Calculation ---
    print(f"\n--- Running TD-DFT for {env_name} ---")
    td = tdscf.TDA(mf)
    td.nroots = 10
    td.kernel()
    
    # --- C. Extract and Print Results ---
    tdms = td.transition_dipole()
    
    print("\n" + "-"*60)
    print(f" FINAL RESULTS: {env_name.upper()} ")
    print("-" * 60)
    print(f"{'State':<8} {'Energy (eV)':<12} {'X':<10} {'Y':<10} {'Z':<10}")
    print("-" * 60)
    
    for i in range(td.nroots):
        tx, ty, tz = tdms[i]
        energy_ev = td.e[i] * 27.2114
        print(f"{i+1:<8} {energy_ev:<12.3f} {tx:<10.4f} {ty:<10.4f} {tz:<10.4f}")
        
    print("-" * 60 + "\n")#INFO: ******************** input file end ********************


