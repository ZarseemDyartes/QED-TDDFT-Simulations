#INFO: **** input file is /global/scratch/users/vaibhavvaiyakarnam/bdp_tddft/coumarin343_solvents.py ****
from pyscf import gto, scf, tdscf

# ==========================================
# 1. MOLECULE SETUP (Exact Cycle 20 Coords)
# ==========================================
mol = gto.Mole()
mol.verbose = 4
mol.atom = '''
